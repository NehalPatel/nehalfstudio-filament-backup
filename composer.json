{
    "name": "nehalfstudio/filament-backup",
    "description": "Laravel Filament admin backups: database dump, storage ZIP, local and Google Drive destinations, retention, and optional scheduler.",
    "type": "library",
    "license": "MIT",
    "homepage": "https://github.com/NehalPatel/nehalfstudio-filament-backup",
    "authors": [
        {
            "name": "Nehalf Studio"
        }
    ],
    "support": {
        "issues": "https://github.com/NehalPatel/nehalfstudio-filament-backup/issues",
        "source": "https://github.com/NehalPatel/nehalfstudio-filament-backup"
    },
    "require": {
        "php": "^8.2",
        "filament/filament": "^5.0",
        "google/apiclient": "^2.15",
        "illuminate/console": "^12.0",
        "illuminate/contracts": "^12.0",
        "illuminate/database": "^12.0",
        "illuminate/filesystem": "^12.0",
        "illuminate/notifications": "^12.0",
        "illuminate/support": "^12.0",
        "symfony/process": "^7.0"
    },
    "require-dev": {
        "laravel/framework": "^12.0",
        "orchestra/testbench": "^10.0",
        "phpunit/phpunit": "^11.5"
    },
    "autoload": {
        "psr-4": {
            "NehalfStudio\\FilamentBackup\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "NehalfStudio\\FilamentBackup\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "NehalfStudio\\FilamentBackup\\FilamentBackupServiceProvider"
            ]
        }
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
